#include <LiquidCrystal_I2C.h>
#include <Wire.h> 
#include <Servo.h>

LiquidCrystal_I2C lcd(0x27,20,4);  // set the LCD address to 0x27 for a 20 chars and 4 line display

#define STEPX_PIN 9 //x axis motor
#define DIRX_PIN 5
#define STEPY_PIN 8 //y axis motor
#define DIRY_PIN 6
#define STEPZ_PIN 4 //z axis motor
#define DIRZ_PIN 7

#define LIMB_X 2  //limit button for X
#define LIMB_Y 3  //limit button for Y
#define ZBTN 12   //Button for starting z movement

Servo myServo;    //creates an object for servo type
int currentAngle = 80; // Stores the last angle we told the servo to go to

int lastZbuttonState = HIGH;            // Stores previous button state so we can detect changes
unsigned long lastDebounceTime = 0;     // Stores last time the button press was accepted
const unsigned long debounceDelay = 50; // Stores previous button state so we can detect changes

int spin = 200;
const int JOY_RIGHT = A0; //white
const int JOY_LEFT  = A3; //yellow
const int JOY_UP    = A1; //orange
const int JOY_DOWN  = A2; //brown

// State:
int FORWARDS = 1;
int IDLE = 0;
int BACKWARDS = -1;

bool lastXdirection = HIGH; // remembers the last X dir, so when a limb is hit we can move in opposite dir.
bool lastYdirection = HIGH; // remembers the last Y dir, so when a limb is hit we can move in opposite dir.
bool xLimitHandled = false; // true after reacting to the current X limb press; reset when switch is released.
bool yLimitHandled = false; // true after reacting to the current Y limb press; reset when switch is released.

void setup() {
  pinMode(STEPX_PIN, OUTPUT); //set pin modes
  pinMode(DIRX_PIN, OUTPUT);
  pinMode(STEPY_PIN, OUTPUT);
  pinMode(DIRY_PIN, OUTPUT);
  pinMode(STEPZ_PIN, OUTPUT);
  pinMode(DIRZ_PIN, OUTPUT);

  pinMode(LIMB_X, INPUT_PULLUP);  //limit buttons
  pinMode(LIMB_Y, INPUT_PULLUP);

  pinMode(ZBTN, INPUT_PULLUP); //claw move button

  //joystick switches
  pinMode(JOY_RIGHT, INPUT_PULLUP); // y directions
  pinMode(JOY_LEFT, INPUT_PULLUP);
  pinMode(JOY_UP, INPUT_PULLUP);    // x directons
  pinMode(JOY_DOWN, INPUT_PULLUP);

  Serial.begin(9600);
  lcd.init();
  lcd.backlight();

  myServo.attach(11); //servo pin

  moveServo(60); //move servo to starting position; closed claw
  //printServoAngle();

  Serial.println("setup done");
}

void loop() {
  
  bool xLimitPressed = digitalRead(LIMB_X) == HIGH; //N.C. limit switches: HIGH means pressed/open
  bool yLimitPressed = digitalRead(LIMB_Y) == HIGH;

  if(checkZButtonPressed()) {
    runSequence();
    homeXY();
    openClaw();
  }

//"escape" if's:
  if (xLimitPressed && !xLimitHandled) {      // condition: if(true && true), so "escape" happens only once for a limit press
    xLimitHandled = true;                     // set x handled to true so "escape" only runs once. now it's: if(true && false)
    ENGINE(true, 150, 300, !lastXdirection, false);  // move a few steps in opposite dir from xlimb, and seperate escape move from joystick move w/ false
    return;                                   // skip joystick controlled movement for the rest of this loop
  }

  if(!xLimitPressed) {
    xLimitHandled = false;         //switch released -> allow the next press to trigger "escape"
  }   

  if (yLimitPressed && !yLimitHandled) {      
    yLimitHandled = true;
    ENGINE(false, 150, 300, !lastYdirection, false);
    return;
  }

  if(!yLimitPressed) {
    yLimitHandled = false;
  }

  // arcade joystick controlled movement:
  MOVE(true, checkButtonMovement(JOY_DOWN, JOY_UP)); // X axis = true
  MOVE(false, checkButtonMovement(JOY_RIGHT, JOY_LEFT));   // Y axis = false
  
}

void MOVE(bool isX, int axis) { //moving on an axis, which one?

  if (axis == FORWARDS) {         //if axis = 1, move in HIGH direction

    if(isX) {
      lastXdirection = HIGH;
    }else{
      lastYdirection = HIGH;
    }
  
    ENGINE(isX, spin, 500, HIGH, true); //true meaning a part of joystick movement and does not "ignore" when limit is pressed

  } else if (axis == BACKWARDS) { // if axis = -1, move in LOW direction

    if(isX) {
      lastXdirection = LOW;
    }else{
      lastYdirection = LOW;
    }

    ENGINE(isX, spin, 500, LOW, true);
  }
}

int checkButtonMovement(int forwardPin, int backwardPin) {
  bool forwardPressed = digitalRead(forwardPin) == HIGH;
  bool backwardPressed = digitalRead(backwardPin) == HIGH;

  if (forwardPressed && !backwardPressed) {
    return FORWARDS;
  } else if (backwardPressed && !forwardPressed) {
    return BACKWARDS;
  } else {
    return IDLE;
  }
}

void ENGINE(bool isX, int steps, int speed, bool direction, bool checkLimit) {

  int dirPin = isX ? DIRX_PIN : DIRY_PIN;
  int stepPin = isX ? STEPX_PIN : STEPY_PIN;
  int limitPin = isX ? LIMB_X : LIMB_Y;
  //can do serial print for this

  digitalWrite(dirPin, direction); //inserts every cycle HIGH/LOW based on joy movement (frwrds/bkwrds/idle)
  for(int i = 0; i < steps; i++){

  bool limitPressed = digitalRead(limitPin) == HIGH;

  if(checkLimit) { // seperates into two types of movement - joystick and escape, so escape can work even when stopping ENGINE();
      if(limitPressed){
        return; // stops motor immediately without waiting for 500 steps (from joystick) to finish
      }
    }

    engineCycle(stepPin, speed);
  }
}

void moveServo(int angle) { 
  myServo.write(angle); //move servo to inputted angle
  currentAngle = angle; //remember where we told it to go
}

void printServoAngle() { //optional debugging fuction for servo (prints current angle)
  Serial.print("servo angle: ");
  Serial.println(currentAngle);
}

bool checkZButtonPressed() {            //debouncer for ZBTN
  int currentState = digitalRead(ZBTN); //read current state of ZBTN = high/low

  if (lastZbuttonState == LOW && currentState == HIGH) { //detect if the button is pressed

    // debounce check
    if (millis() - lastDebounceTime > debounceDelay) {
      lastDebounceTime = millis();
      lastZbuttonState = currentState;
      return true;  // valid press detected
    }
  }

  lastZbuttonState = currentState;
  return false;
}

void ZACTIVE(int dirPin, int stepPin, int steps, int speed, int direction) {

  digitalWrite(dirPin, direction); //set direction HIGH/LOW

  for(int i = 0; i < steps; i++) {
    engineCycle(stepPin, speed);
  }
}

void runSequence() { //claw opening and closing fuction

  // Stepper forward -> down z axis
  ZACTIVE(DIRZ_PIN, STEPZ_PIN, 3000, 500, HIGH);

  delay(1000);

  // Servo move to opened claw
  moveServo(10);

  delay(1000);

  // Stepper again
  ZACTIVE(DIRZ_PIN, STEPZ_PIN, 800, 500, HIGH);

  // Servo back to closed claw
  moveServo(60);

  delay(1000);

  // Stepper reverse -> up z axis
  ZACTIVE(DIRZ_PIN, STEPZ_PIN, 4000, 500, LOW);

  delay(1000);

  //after doing claw sequence, move to "home" sequence:
  ENGINE(true, spin, 500, LOW, true); //move left on x axis a certain amount of steps(ntc!) until reaching limbx

}

void homeXY() {

  bool xDone = false;

  while (!xDone) {

    bool xLimit = digitalRead(LIMB_X) == HIGH;

    if (!xLimit) {
      ENGINE(true, 1, 400, HIGH, true);
    } 
    else {
      ENGINE(true, 200, 300, LOW, false);
      xDone = true;
    }
  }

  delay(200);

  bool yDone = false;

  while (!yDone) {

    bool yLimit = digitalRead(LIMB_Y) == HIGH;

    if (!yLimit) {
      ENGINE(false, 1, 400, LOW, true);
    } 
    else {
      ENGINE(false, 200, 300, HIGH , false);
      yDone = true;
    }
  }


}

void openClaw() {
  
  moveServo(0);
  delay(1000);

  moveServo(80);
  delay(1000);
}


void engineCycle(int ste, int spe) {  // one step/pulse sequence for the motors
  digitalWrite(ste, HIGH);
  delayMicroseconds(spe);
  digitalWrite(ste, LOW);
  delayMicroseconds(spe);
}

